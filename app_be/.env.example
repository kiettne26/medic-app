# =========================================================================
#  ENVIRONMENT VARIABLES FOR MEDICAL BOOKING SYSTEM - EXAMPLE template
#  Rename to .env and fill in your actual values.
# =========================================================================

# Database Supabase configuration
SUPABASE_HOST=your-supabase-host.supabase.co
SUPABASE_PORT=5432
SUPABASE_USER=postgres
SUPABASE_PASSWORD=your-supabase-password

# Security & Core API Keys
JWT_SECRET=your-jwt-secret-key-at-least-256-bit
GEMINI_API_KEY=your-gemini-api-key

# Gmail SMTP configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-sender@gmail.com
MAIL_PASSWORD=your-16-character-gmail-app-password
MAIL_FROM_NAME=MediBook

# ZaloPay integration configuration
ZALOPAY_APP_ID=0
ZALOPAY_KEY1=your-zalopay-key1
ZALOPAY_KEY2=your-zalopay-key2
ZALOPAY_CREATE_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
ZALOPAY_QUERY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/query
ZALOPAY_MERCHANT_NAME=MediBook
# ZALOPAY_CALLBACK_URL=https://your-domain.com/api/bookings/payment/zalopay/callback
# ZALOPAY_REDIRECT_URL=medicapp://payment-result
